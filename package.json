{
  "name": "uxray",
  "version": "1.0.0",
  "description": "Automated WCAG 2.1 AA accessibility and responsiveness auditor for React apps",
  "type": "module",
  "bin": {
    "uxray": "./bin/uxray.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./config": "./src/config.js"
  },
  "scripts": {
    "test":              "node --test tests/*.test.js",
    "test:bedrock":      "node test-bedrock.js",
    "test:level2":       "node tests/test-level2-html-parser.js",
    "test:level3":       "node tests/test-level3-json-dryrun.js",
    "test:level4":       "node tests/test-level4-html-dryrun.js",
    "test:level5":       "node tests/test-level5-live-bedrock.js",
    "test:offline":      "npm run test:level2",
    "test:aws":          "npm run test:bedrock && npm run test:level3 && npm run test:level4",
    "test:all":          "npm run test:level2 && npm run test:level3 && npm run test:level4 && npm run test:level5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.600.0",
    "@aws-sdk/client-sts": "^3.1076.0",
    "@axe-core/playwright": "^4.9.1",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "playwright": "^1.44.1"
  }
}
