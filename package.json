{
  "name": "uxray",
  "version": "1.0.0",
  "description": "Automated WCAG 2.1 AA accessibility and responsiveness auditor for React apps",
  "type": "module",
  "bin": {
    "uxray": "./bin/uxray.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./config": "./src/config.js"
  },
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:bedrock": "node --env-file=.env bin/uxray.js --bedrock-check",
    "test:connection": "node --env-file=.env bin/uxray.js --bedrock-check",
    "test:responsive": "playwright test --config tests/playwright.config.ts tests/integration/responsive.spec.ts",
    "test:responsive:update": "playwright test --config tests/playwright.config.ts tests/integration/responsive.spec.ts --update-snapshots"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.600.0",
    "@aws-sdk/client-sts": "^3.1076.0",
    "@axe-core/playwright": "^4.9.1",
    "playwright": "^1.44.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
