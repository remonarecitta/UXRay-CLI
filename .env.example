# ─────────────────────────────────────────────────────────────
#  UXRay — AWS Bedrock credentials template
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────

# AWS region where your Bedrock model is enabled
# Claude 3.5 Sonnet v2 is available in: us-west-2, us-east-1
AWS_DEFAULT_REGION=us-west-2
AWS_REGION=us-west-2

# Long-term IAM credentials (use if NOT using temporary session tokens)
AWS_ACCESS_KEY_ID=your-access-key-id-here
AWS_SECRET_ACCESS_KEY=your-secret-access-key-here

# Temporary session token — required when using AWS SSO or assumed roles.
# Leave blank if using long-term IAM credentials.
# Session tokens expire in 1–12 hours; re-run your AWS login to refresh.
AWS_SESSION_TOKEN=

